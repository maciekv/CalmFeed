{
  "name": "calmfeed",
  "version": "1.0.0",
  "description": "Chrome extension that filters negative news content using AI",
  "private": true,
  "license": "MIT",
  "author": "Maciej Osytek",
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "download-model": "tsx scripts/download-model.ts",
    "clean": "rm -rf dist",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.0",
    "mini-css-extract-plugin": "^2.9.0",
    "prettier": "^3.4.0",
    "ts-loader": "^9.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  }
}
